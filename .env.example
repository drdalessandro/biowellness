# BIOWELLNESS — Environment Configuration
#
# Copy to .env.local and fill with real values.
# Production values live in AWS Secrets Manager / SSM Parameter Store.

# ─── Medplum Backend (CANONICAL) ────────────────────────────────────────
# El backend está en api.medplum.com.ar, NO en api.biowellness.ar.
# Si tu config legacy todavía usa api.biowellness.ar, es CNAME válido pero deprecado.
MEDPLUM_BASE_URI=https://api.medplum.com.ar

# Project ID del Project "biowellness" en Medplum
# Obtenible via app.medplum.com.ar > Projects > biowellness > id
MEDPLUM_PROJECT_ID=

# ClientApplication para deploy (FHIR-as-Code script)
# Generar en app.medplum.com.ar con AccessPolicy de SuperAdmin
MEDPLUM_CLIENT_ID=
MEDPLUM_CLIENT_SECRET=

# ─── Frontend URLs ──────────────────────────────────────────────────────
# Para CORS allowed origins y OAuth redirect config
BIOWELLNESS_CHART_URL=https://app.biowellness.ar
BIOWELLNESS_PORTAL_URL=https://portal.biowellness.ar
MEDPLUM_APP_URL=https://app.medplum.com.ar
BIOWELLNESS_PUBLIC_URL=https://www.biowellness.ar

# ─── Cross-org bridge (H2 2026, no usar en MVP) ────────────────────────
EPA_BIENESTAR_API_URL=https://api.epa-bienestar.com.ar
EPA_BIENESTAR_API_KEY=

# ─── External LLM (Bot evaluate-fenotipo Layer 2) ──────────────────────
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── External Messaging ─────────────────────────────────────────────────
KAPSO_WHATSAPP_TOKEN=
POSTMARK_API_TOKEN=

# ─── Payments ───────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=

# ─── AWS Region ─────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# ─── Local Dev Overrides ────────────────────────────────────────────────
# Para desarrollo local apuntando a staging
# MEDPLUM_BASE_URI=https://api-staging.medplum.com.ar
# MEDPLUM_PROJECT_ID=<staging project id>

# ─── Notes ──────────────────────────────────────────────────────────────
# 1. api.biowellness.ar quedó DEPRECADA en RC3. Use api.medplum.com.ar.
# 2. portal.biowellness.ar es V2, no usar en MVP.
# 3. Project tenancy: todos los recursos van al Project biowellness, no a SuperAdmin.
